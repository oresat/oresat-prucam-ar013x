#!/usr/bin/make -f

export PRU_CGT=/usr/share/ti/cgt-pru

include /usr/share/dpkg/pkg-info.mk

%:
	dh $@ --with dkms

override_dh_install:
	# device tree
	make -C device_tree_overlay clean all
	# pru fw
	make -C pru_code clean all
	# dkms
	mkdir -p etc/modules-load.d
	echo "prucam" > etc/modules-load.d/prucam.conf
	dh_install kernel_module/* usr/prucam-$(DEB_VERSION_UPSTREAM)/

override_dh_dkms:
	dh_dkms -V $(DEB_VERSION_UPSTREAM)

override_dh_auto_test:
